# Wardress environment configuration
# ------------------------------------------------------------------
# DO NOT use this file directly. scripts/install.ps1 copies it to
# `.env` and replaces every CHANGE_ME with a cryptographically random
# value on first run. `.env` is gitignored and must never be committed.
# ------------------------------------------------------------------

# --- Core ---
WARDRESS_HTTP_PORT=8321
WARDRESS_ENV=production
# Base URL used in alert links (email/Telegram "open dashboard" links).
# Change if you front Wardress with a reverse proxy or custom hostname.
PUBLIC_BASE_URL=http://localhost:8321

# --- Database (Postgres 16) ---
POSTGRES_USER=wardress
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_AT_INSTALL
POSTGRES_DB=wardress
DATABASE_URL=postgresql+asyncpg://wardress:CHANGE_ME_GENERATED_AT_INSTALL@db:5432/wardress

# --- Redis (broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Security secrets (generated at install, never defaulted) ---
JWT_SECRET=CHANGE_ME_GENERATED_AT_INSTALL
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_GENERATED_AT_INSTALL

# --- First admin user (used by `python -m app.seed_admin` in the app
#     container; password must be at least 12 characters) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_GENERATED_AT_INSTALL

# --- Optional intelligence layer (both off by default) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Set ENABLE_OLLAMA=true to start the optional local-LLM container
ENABLE_OLLAMA=false
OLLAMA_BASE_URL=http://ollama:11434/v1

# --- Optional Telegram interactive bot ---
TELEGRAM_BOT_TOKEN=

# --- API rate limiting (Phase 5; 0 disables a limit) ---
# Requests per window per client IP (pre-auth) and per user (post-auth).
RATE_LIMIT_PER_IP=300
RATE_LIMIT_PER_USER=240
RATE_LIMIT_WINDOW_SECONDS=60
# Set true ONLY behind a trusted reverse proxy that sets X-Forwarded-For.
TRUST_PROXY_HEADERS=false

# --- CORS (Phase 5) ---
# The SPA is served same-origin, so this stays empty (no cross-origin
# requests allowed). Set a comma-separated origin list only if you host
# the frontend elsewhere.
CORS_ALLOWED_ORIGINS=

# --- HTTPS fronting ---
# Wardress serves plain HTTP on WARDRESS_HTTP_PORT; for anything beyond
# localhost, front it with an HTTPS reverse proxy (Caddy, nginx,
# Traefik). When you do: set PUBLIC_BASE_URL to the https:// address,
# set TRUST_PROXY_HEADERS=true, and set COOKIE_SECURE=true so the
# refresh-token cookie is only ever sent over HTTPS.
COOKIE_SECURE=false
