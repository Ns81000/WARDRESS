# Normalize to LF in the repo; checkout as-is. Prevents CRLF churn on the
# Windows dev host and keeps Docker/CI (Linux) happy with shell scripts.
* text=auto eol=lf

# Windows scripts genuinely need CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.ico binary
*.woff2 binary
